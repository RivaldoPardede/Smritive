<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon (Android 8.0+ / API 26+).
  Background: solid brand color from colors.xml (per flavor if needed).
  Foreground: PNG produced by tool/gen_icons.ps1 with 20% inset (66dp safe zone).
  Monochrome: same foreground reused for Android 13+ themed icons.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background"/>
    <foreground android:drawable="@drawable/ic_launcher_foreground"/>
    <monochrome android:drawable="@drawable/ic_launcher_foreground"/>
</adaptive-icon>
